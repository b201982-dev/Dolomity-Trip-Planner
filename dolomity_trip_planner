    <!-- Leaflet.js Map script -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

    <script>
        // Set up the Leaflet map centered around Dolomites
        let map;
        let markers = {};

        function initMap() {
            // Dolomites Center coordinates
            const doloCenter = [46.66, 12.15];
            map = L.map('map', {
                scrollWheelZoom: false
            }).setView(doloCenter, 10);

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);

            // Coordinates for important day destinations
            const destinations = [
                { id: 1, name: "Zakwaterowanie (Dobbiaco / San Candido)", coords: [46.7329, 12.2798], desc: "Nasza baza wypadowa" },
                { id: 2, name: "Lago di Braies", coords: [46.6943, 12.0847], desc: "Trasa rowerowa 21km & urocze łódki" },
                { id: 3, name: "Tre Cime & Cadini di Misurina", coords: [46.6125, 12.2952], desc: "Kultowy trekking 10km i punkt widokowy" },
                { id: 4, name: "Lago di Dobbiaco & Prato Piazza", coords: [46.7231, 12.2183], desc: "Relaks rowerowy, piknik i łąki Prato Piazza" },
                { id: 6, name: "Seceda (Col Raiser)", coords: [46.5982, 11.7247], desc: "Kolejka górska, spektakularne klify i schroniska" },
                { id: 7, name: "Stawy Kąpielowe Dobbiaco", coords: [46.728, 12.222], desc: "Pełen chillout wodny za 5€" },
                { id: 8, name: "Lago di Sorapis", coords: [46.5559, 12.1673], desc: "Start rano przed 7:00! Turkusowa woda" },
                { id: 9, name: "San Candido - Cortina d'Ampezzo", coords: [46.5405, 12.1357], desc: "Rowerowa trasa Lunga via delle Dolomiti" }
            ];

            // Add markers
            destinations.forEach(dest => {
                const marker = L.marker(dest.coords).addTo(map)
                    .bindPopup(`<b>Dzień ${dest.id === 4 ? '4-5' : dest.id}: ${dest.name}</b><br>${dest.desc}`);
                markers[dest.id] = marker;
            });
        }

        // Focus map zoom helper
        function focusMap(lat, lng, zoom, dayId) {
            if (map) {
                map.setView([lat, lng], zoom);
                if (markers[dayId]) {
                    markers[dayId].openPopup();
                }
                
                // Visual feedback in DOM
                document.querySelectorAll('.day-card').forEach(card => {
                    card.classList.remove('ring-2', 'ring-emerald-500', 'ring-offset-2');
                });
                const activeCard = document.getElementById(`day-${dayId}-anchor`);
                if (activeCard) {
                    activeCard.classList.add('ring-2', 'ring-emerald-500', 'ring-offset-2');
                    activeCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
                }
            }
        }

        // Filter Timeline Days
        function filterDays(type) {
            // Update filter buttons states
            document.querySelectorAll('.filter-btn').forEach(btn => {
                btn.classList.remove('bg-slate-900', 'text-white');
                btn.classList.add('bg-white', 'text-slate-600', 'border', 'border-slate-200');
            });
            event.target.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
            event.target.classList.add('bg-slate-900', 'text-white');

            // Show/hide cards
            document.querySelectorAll('.day-card').forEach(card => {
                if (type === 'all' || card.getAttribute('data-type') === type) {
                    card.classList.remove('hidden');
                } else {
                    card.classList.add('hidden');
                }
            });
        }

        // Update Weekdays based on User Start Date input
        const polishWeekdays = ["Niedziela", "Poniedziałek", "Wtorek", "Środa", "Czwartek", "Piątek", "Sobota"];
        function updateTripDates() {
            const inputDateVal = document.getElementById('tripStartDate').value;
            if (!inputDateVal) return;

            const baseDate = new Date(inputDateVal);
            document.querySelectorAll('.dynamic-day-name').forEach(el => {
                const offset = parseInt(el.getAttribute('data-day-offset'), 10);
                const targetDate = new Date(baseDate);
                targetDate.setDate(baseDate.getDate() + offset);

                const formattedDate = targetDate.toLocaleDateString('pl-PL', {
                    day: 'numeric',
                    month: 'long'
                });
                const dayOfWeek = polishWeekdays[targetDate.getDay()];
                
                el.innerHTML = `Dzień ${offset + 1} — ${dayOfWeek}, ${formattedDate}`;
            });

            // Refresh Countdown base date
            countdownTargetDate = baseDate;
            saveTripStartDate(inputDateVal);
        }

        // Local Storage handles for Trip Start Date
        function saveTripStartDate(dateString) {
            localStorage.setItem('dolomity_start_date', dateString);
        }

        function loadTripStartDate() {
            const saved = localStorage.getItem('dolomity_start_date');
            if (saved) {
                document.getElementById('tripStartDate').value = saved;
            }
        }

        // Packing List Interactive Checks
        function togglePackItem(element) {
            const checkbox = element.querySelector('input[type="checkbox"]');
            if (event.target !== checkbox) {
                checkbox.checked = !checkbox.checked;
            }
            savePackingState();
        }

        function savePackingState() {
            const states = {};
            document.querySelectorAll('input[type="checkbox"]').forEach(box => {
                states[box.id] = box.checked;
            });
            localStorage.setItem('dolomity_packing_states', JSON.stringify(states));
        }

        function loadPackingState() {
            const saved = localStorage.getItem('dolomity_packing_states');
            if (saved) {
                const states = JSON.parse(saved);
                Object.keys(states).forEach(id => {
                    const box = document.getElementById(id);
                    if (box) box.checked = states[id];
                });
            }
        }

        // Live Countdown Clock
        let countdownTargetDate = new Date("2026-07-15T08:00:00");
        function updateCountdown() {
            const now = new Date().getTime();
            const difference = countdownTargetDate.getTime() - now;

            if (difference < 0) {
                document.getElementById('days').innerText = "00";
                document.getElementById('hours').innerText = "00";
                document.getElementById('minutes').innerText = "00";
                document.getElementById('seconds').innerText = "00";
                return;
            }

            const days = Math.floor(difference / (1000 * 60 * 60 * 24));
            const hours = Math.floor((difference % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((difference % (1000 * 60 * 60)) / (1000 * 60));
            const seconds = Math.floor((difference % (1000 * 60)) / 1000);

            document.getElementById('days').innerText = String(days).padStart(2, '0');
            document.getElementById('hours').innerText = String(hours).padStart(2, '0');
            document.getElementById('minutes').innerText = String(minutes).padStart(2, '0');
            document.getElementById('seconds').innerText = String(seconds).padStart(2, '0');
        }

        // Initializer
        window.onload = function () {
            loadTripStartDate();
            updateTripDates();
            initMap();
            loadPackingState();
            
            // Start real-time countdown
            updateCountdown();
            setInterval(updateCountdown, 1000);
        };
    </script>
</body>
</html>
